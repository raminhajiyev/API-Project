@using WebApp.DTOs.ProductDTO
@using Microsoft.AspNetCore.Mvc.Rendering
@model UpdateProductDTO

@{
    ViewData["Title"] = "UpdateProduct";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card">

            <div class="card-header">
                <h4>Update Product</h4>
            </div>

            <form method="post">
                <div class="card-body">

                    <input type="hidden" asp-for="ProductId" />

                    <div class="form-group row mb-4">
                        <label class="col-form-label text-md-right col-12 col-md-3 col-lg-3">
                            Product Name
                        </label>
                        <div class="col-sm-12 col-md-7">
                            <input type="text" class="form-control" asp-for="ProductName" />
                        </div>
                    </div>

                    <div class="form-group row mb-4">
                        <label class="col-form-label text-md-right col-12 col-md-3 col-lg-3">
                            Price
                        </label>
                        <div class="col-sm-12 col-md-7">
                            <input type="text" class="form-control" asp-for="Price" />
                        </div>
                    </div>

                    <div class="form-group row mb-4">
                        <label class="col-form-label text-md-right col-12 col-md-3 col-lg-3">
                            Category
                        </label>
                        <div class="col-sm-12 col-md-7">
                               <select asp-for="CategoryId" class="form-control">
                                <option value="">--Category--</option>
                                @foreach (var item in (List<SelectListItem>)ViewBag.v)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="form-group row mb-4">
                        <label class="col-form-label text-md-right col-12 col-md-3 col-lg-3">
                            Description
                        </label>
                        <div class="col-sm-12 col-md-7">
                            <textarea class="form-control" asp-for="ProductDescription"></textarea>
                        </div>
                    </div>

                    <div class="form-group row mb-4">
                        <label class="col-form-label col-12 col-md-3 col-lg-3"></label>
                        <div class="col-sm-12 col-md-7">
                            <button class="btn btn-primary">Save</button>
                        </div>
                    </div>

                </div>
            </form>

        </div>
    </div>
</div>