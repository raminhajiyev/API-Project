@using WebApp.DTOs.TestimonialDTO
@model List<TestimonialResultDTO>
@{
    ViewData["Title"] = "TestimonialList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}


<div class="section-body">
    <div class="row">
        <div class="col-12 col-md-6 col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h4>Testimonials</h4>
                </div>
                <div class="card-body">
                    <table class="table">
                        <thead>
                            <tr>
                                <th scope="col">#</th>
                                <th scope="col">Fullname</th>
                                <th scope="col">Title</th>
                                <th scope="col">Comment</th>
                                <th scope="col">Delete</th>
                                <th scope="col">Edit</th>
                            </tr>
                        </thead>
                        <tbody>

                            @foreach (var item in Model)
                            {
                                count
                                ++;
                                <tr>
                                    <th scope="row">@count</th>
                                    <td>@item.Fullname</td>
                                    <td>@item.Title</td>
                                    <td>@item.Comment</td>
                                    <td><a href="/AdminTestimonial/DeleteTestimonial/@item.TestimonialID/" class="btn btn-danger">Delete</a></td>
                                    <td><a href="/AdminTestimonial/UpdateTestimonial/@item.TestimonialID/" class="btn btn-success">Edit</a></td>
                                </tr>
                            }

                        </table>
                        <br />
                        <a href="/AdminTestimonial/AddTestimonial/" style="color: white;" class="btn btn-primary">Add Testimonial</a>
                    </div>
                </div>
            </div>
        </div>
    </div>




