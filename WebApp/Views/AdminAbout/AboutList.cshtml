@using WebApp.DTOs.AboutDTO
@model List<ResultAboutDTO>
@{
    ViewData["Title"] = "AboutList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<div class="section-body">
    <div class="row">
        <div class="col-12 col-md-6 col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h4>About</h4>
                </div>
                <div class="card-body">
                    <table class="table">
                        <thead>
                            <tr>
                                <th scope="col">#</th>
                                <th scope="col">Title</th>
                                <th scope="col">Phone</th>
                                <th scope="col">Description</th>
                                <th scope="col">Delete</th>
                                <th scope="col">Edit</th>
                            </tr>
                        </thead>
                        <tbody>

                            @foreach (var item in Model)
                            {
                                count
                                ++;
                                <tr>
                                    <th scope="row">@count</th>
                                    <td>@item.Title</td>
                                    <td>@item.Phone</td>
                                    <td>@item.Description</td>
                                    <td><a href="/AdminAbout/DeleteAbout/@item.AboutId/" class="btn btn-danger">Delete</a></td>
                                    <td><a href="/AdminAbout/UpdateAbout/@item.AboutId/" class="btn btn-success">Edit</a></td>
                                </tr>
                            }

                        </table>
                        <br />
                        @if (Model.Count == 0)
                        {
                            <div class="alert alert-danger" role="alert">
                                No data found!
                            </div>
                            <a href="/AdminAbout/AddAbout/" style="color: white;" class="btn btn-primary">Add About</a>
                        }
                        else if (Model.Count == 1)
                        {
                            <a href="#" style="color: white;" class="btn btn-danger" onclick="disabled">Already exist!</a>
                        }
 
                    </div>
                </div>
            </div>
        </div>
    </div>


